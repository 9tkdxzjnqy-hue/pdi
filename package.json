{
  "name": "pdi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/sync.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "seed:hall-of-fame": "export $(grep -v '^#' .env.local | xargs) && tsx scripts/seed-inductees.ts",
    "seed:competitions": "export $(grep -v '^#' .env.local | xargs) && tsx scripts/seed-competitions.ts",
    "seed:gallery": "export $(grep -v '^#' .env.local | xargs) && tsx scripts/seed-gallery.ts",
    "seed:stories": "export $(grep -v '^#' .env.local | xargs) && tsx scripts/seed-stories.ts",
    "seed:homepage": "export $(grep -v '^#' .env.local | xargs) && tsx scripts/seed-homepage.ts",
    "sync": "export $(grep -v '^#' .env.local | xargs) && tsx scripts/sync.ts"
  },
  "dependencies": {
    "@sanity/image-url": "^2.0.3",
    "next": "^15.3.0",
    "next-sanity": "^9.12.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
